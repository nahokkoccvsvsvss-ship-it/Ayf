function LuxuryGUI:AddSlider(parent, text, minVal, maxVal, default, callback)
    local value = default or minVal
    local dragging = false

    local container = CreateInstance("Frame", {
        Size            = UDim2.new(1, -20, 0, 60),
        Position        = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Parent          = parent,
    })

    local titleRow = CreateInstance("Frame", {
        Size            = UDim2.new(1, 0, 0, 20),
        BackgroundTransparency = 1,
        Parent          = container,
    })

    local titleLabel = CreateInstance("TextLabel", {
        Size            = UDim2.new(0.7, 0, 1, 0),
        BackgroundTransparency = 1,
        Text            = text,
        TextColor3      = CONFIG.COLORS.TEXT_WHITE,
        TextSize        = 13,
        Font            = Enum.Font.Gotham,
        TextXAlignment  = Enum.TextXAlignment.Right,
        Parent          = titleRow,
        Position        = UDim2.new(0.3, 0, 0, 0),
    })

    local valueLabel = CreateInstance("TextLabel", {
        Size            = UDim2.new(0.28, 0, 1, 0),
        BackgroundTransparency = 1,
        Text            = tostring(value),
        TextColor3      = CONFIG.COLORS.GOLD,
        TextSize        = 13,
        Font            = Enum.Font.GothamBold,
        TextXAlignment  = Enum.TextXAlignment.Left,
        Parent          = titleRow,
    })

    local track = CreateInstance("Frame", {
        Size            = UDim2.new(1, 0, 0, 6),
        Position        = UDim2.new(0, 0, 0, 32),
        BackgroundColor3= CONFIG.COLORS.SLIDER_TRACK,
        Parent          = container,
    })
    CreateCorner(track, 3)

    local fill = CreateInstance("Frame", {
        Size            = UDim2.new((value - minVal) / (maxVal - minVal), 0, 1, 0),
        BackgroundColor3= CONFIG.COLORS.GOLD,
        Parent          = track,
    })
    CreateCorner(fill, 3)

    local knob = CreateInstance("Frame", {
        Size            = UDim2.new(0, 16, 0, 16),
        Position        = UDim2.new((value - minVal) / (maxVal - minVal), -8, 0.5, -8),
        BackgroundColor3= CONFIG.COLORS.GOLD,
        Parent          = track,
        ZIndex          = 3,
    })
    CreateCorner(knob, 8)
    CreateStroke(knob, Color3.fromRGB(255, 255, 255), 1)

    local sliderBtn = CreateInstance("TextButton", {
        Size            = UDim2.new(1, 0, 0, 24),
        Position        = UDim2.new(0, 0, 0, -9),
        BackgroundTransparency = 1,
        Text            = "",
        ZIndex          = 4,
        Parent          = track,
    })

    local function updateSlider(inputX)
        local absX    = track.AbsolutePosition.X
        local absW    = track.AbsoluteSize.X
        local ratio   = math.clamp((inputX - absX) / absW, 0, 1)
        value         = math.floor(minVal + (maxVal - minVal) * ratio)
        valueLabel.Text = tostring(value)
        Tween(fill, {Size = UDim2.new(ratio, 0, 1, 0)}, 0.05)
        Tween(knob, {Position = UDim2.new(ratio, -8, 0.5, -8)}, 0.05)
        if callback then callback(value) end
    end

    sliderBtn.MouseButton1Down:Connect(function(x, y)
        dragging = true
        updateSlider(x)
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    return {
        getValue = function() return value end,
        setValue = function(v)
            value = math.clamp(v, minVal, maxVal)
            local ratio = (value - minVal) / (maxVal - minVal)
            valueLabel.Text = tostring(value)
            fill.Size = UDim2.new(ratio, 0, 1, 0)
            knob.Position = UDim2.new(ratio, -8, 0.5, -8)
        end,
    }
end

