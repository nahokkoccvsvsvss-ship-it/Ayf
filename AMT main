-- ═══════════════════════════════════════════════
--              دوال المساعدة
-- ═══════════════════════════════════════════════

local function Tween(obj, props, duration)
    duration = duration or CONFIG.TWEEN_SPEED
    local info = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = TweenService:Create(obj, info, props)
    tween:Play()
    return tween
end

local function CreateInstance(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do
        inst[k] = v
    end
    return inst
end

local function CreateCorner(parent, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or CONFIG.SIZES.RADIUS)
    corner.Parent = parent
    return corner
end

local function CreateStroke(parent, color, thickness)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or CONFIG.COLORS.GOLD
    stroke.Thickness = thickness or CONFIG.SIZES.BORDER_SIZE
    stroke.Parent = parent
    return stroke
end

local function CreatePadding(parent, top, bottom, left, right)
    local pad = Instance.new("UIPadding")
    pad.PaddingTop    = UDim.new(0, top or 0)
    pad.PaddingBottom = UDim.new(0, bottom or 0)
    pad.PaddingLeft   = UDim.new(0, left or 0)
    pad.PaddingRight  = UDim.new(0, right or 0)
    pad.Parent = parent
    return pad
end

local function CreateGradient(parent, fromColor, toColor, rotation)
    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, fromColor),
        ColorSequenceKeypoint.new(1, toColor),
    })
    grad.Rotation = rotation or 90
    grad.Parent = parent
    return grad
end

local function SetStatus(text)
    State.statusText = text
    if _G.LuxStatusLabel then
        _G.LuxStatusLabel.Text = "● " .. text
    end
end

-- ═══════════════════════════════════════════════
--              دالة إنشاء الإشعار
-- ═══════════════════════════════════════════════
function LuxuryGUI:Notify(message, duration)
    if not State.settings.notifications then return end
    duration = duration or 2

    local toastContainer = _G.LuxToastContainer
    if not toastContainer then return end

    local toast = CreateInstance("Frame", {
        Size            = UDim2.new(1, 0, 0, 0),
        BackgroundColor3= CONFIG.COLORS.TOAST_BG,
        BackgroundTransparency = 0.1,
        AutomaticSize   = Enum.AutomaticSize.Y,
        Parent          = toastContainer,
    })
    CreateCorner(toast, 8)
    CreateStroke(toast, CONFIG.COLORS.GOLD, 1)
    CreatePadding(toast, 10, 10, 12, 12)

    local label = CreateInstance("TextLabel", {
        Size            = UDim2.new(1, 0, 0, 0),
        AutomaticSize   = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Text            = message,
        TextColor3      = CONFIG.COLORS.TEXT_WHITE,
        TextSize        = 13,
        Font            = Enum.Font.GothamBold,
        TextXAlignment  = Enum.TextXAlignment.Right,
        TextWrapped     = true,
        Parent          = toast,
    })

    toast.BackgroundTransparency = 1
    Tween(toast, {BackgroundTransparency = 0.1}, 0.3)

    task.delay(duration, function()
        Tween(toast, {BackgroundTransparency = 1}, 0.3)
        task.delay(0.35, function()
            if toast and toast.Parent then
                toast:Destroy()
            end
        end)
    end)
end

