    -- ─────────────────────────────────
    --          شريط الحالة
    -- ─────────────────────────────────
    local statusBar = CreateInstance("Frame", {
        Size            = UDim2.new(1, 0, 0, CONFIG.SIZES.STATUS_H),
        Position        = UDim2.new(0, 0, 0, CONFIG.SIZES.HEADER_H),
        BackgroundColor3= CONFIG.COLORS.STATUS_BG,
        BackgroundTransparency = 0.2,
        Parent          = mainFrame,
    })

    local pulseDot = CreateInstance("Frame", {
        Size            = UDim2.new(0, 10, 0, 10),
        Position        = UDim2.new(0, 12, 0.5, -5),
        BackgroundColor3= CONFIG.COLORS.GREEN_PULSE,
        Parent          = statusBar,
    })
    CreateCorner(pulseDot, 5)

    local statusLabel = CreateInstance("TextLabel", {
        Size            = UDim2.new(1, -30, 1, 0),
        Position        = UDim2.new(0, 28, 0, 0),
        BackgroundTransparency = 1,
        Text            = "● " .. State.statusText,
        TextColor3      = CONFIG.COLORS.TEXT_WHITE,
        TextSize        = 12,
        Font            = Enum.Font.Gotham,
        TextXAlignment  = Enum.TextXAlignment.Left,
        Parent          = statusBar,
    })
    _G.LuxStatusLabel = statusLabel

    -- نبض النقطة الخضراء
    task.spawn(function()
        while screenGui and screenGui.Parent do
            Tween(pulseDot, {BackgroundTransparency = 0.8}, 0.5)
            task.wait(0.5)
            Tween(pulseDot, {BackgroundTransparency = 0}, 0.5)
            task.wait(0.5)
        end
    end)

    -- ─────────────────────────────────
    --          أزرار التابات
    -- ─────────────────────────────────
    local tabsY = CONFIG.SIZES.HEADER_H + CONFIG.SIZES.STATUS_H

    local tabsBar = CreateInstance("Frame", {
        Size            = UDim2.new(1, 0, 0, CONFIG.SIZES.TABS_H),
        Position        = UDim2.new(0, 0, 0, tabsY),
        BackgroundColor3= CONFIG.COLORS.PRIMARY_BG,
        BackgroundTransparency = 0.3,
        Parent          = mainFrame,
    })

    local TABS = {
        {name = "الرئيسية", icon = "🏠"},
        {name = "البحث",    icon = "🔍"},
        {name = "الانتقال", icon = "🌍"},
        {name = "الإعدادات",icon = "⚙️"},
    }
    local tabButtons   = {}
    local tabSlider    = CreateInstance("Frame", {
        Size            = UDim2.new(1 / #TABS, -8, 0, 3),
        Position        = UDim2.new(0, 4, 1, -4),
        BackgroundColor3= CONFIG.COLORS.GOLD,
        Parent          = tabsBar,
    })
    CreateCorner(tabSlider, 2)

    local tabW = 1 / #TABS
    for i, tab in ipairs(TABS) do
        local tbtn = CreateInstance("TextButton", {
            Size            = UDim2.new(tabW, 0, 1, 0),
            Position        = UDim2.new(tabW * (i - 1), 0, 0, 0),
            BackgroundTransparency = 1,
            Text            = tab.icon .. " " .. tab.name,
            TextColor3      = i == 1 and CONFIG.COLORS.GOLD or CONFIG.COLORS.TEXT_GRAY,
            TextSize        = 12,
            Font            = i == 1 and Enum.Font.GothamBold or Enum.Font.Gotham,
            AutoButtonColor = false,
            Parent          = tabsBar,
        })
        tabButtons[i] = tbtn
    end

    -- ─────────────────────────────────
    --          منطقة المحتوى
    -- ─────────────────────────────────
    local contentY  = tabsY + CONFIG.SIZES.TABS_H
    local contentH  = CONFIG.SIZES.HEIGHT - contentY

    local contentArea = CreateInstance("ScrollingFrame", {
        Size                = UDim2.new(1, 0, 0, contentH),
        Position            = UDim2.new(0, 0, 0, contentY),
        BackgroundTransparency = 1,
        ScrollBarThickness  = 4,
        ScrollBarImageColor3= CONFIG.COLORS.GOLD,
        CanvasSize          = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Parent              = mainFrame,
    })

    -- إنشاء صفحات التابات
    local tabPages = {}
    for i = 1, #TABS do
        local page = CreateInstance("Frame", {
            Size            = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Visible         = i == 1,
            Parent          = contentArea,
        })
        local layout = Instance.new("UIListLayout")
        layout.SortOrder = Enum.SortOrder.LayoutOrder
        layout.Padding = UDim.new(0, 10)
        layout.Parent = page
        CreatePadding(page, 10, 10, 0, 0)
        tabPages[i] = page
    end

    -- منطق التابات
    local function switchTab(idx)
        State.activeTab = idx
        for i, btn in ipairs(tabButtons) do
            local active = i == idx
            btn.TextColor3 = active and CONFIG.COLORS.GOLD or CONFIG.COLORS.TEXT_GRAY
            btn.Font = active and Enum.Font.GothamBold or Enum.Font.Gotham
            tabPages[i].Visible = active
        end
        local targetX = tabW * (idx - 1)
        Tween(tabSlider, {Position = UDim2.new(targetX, 4, 1, -4)})
        contentArea.CanvasPosition = Vector2.new(0, 0)
    end

    for i, btn in ipairs(tabButtons) do
        btn.MouseButton1Click:Connect(function()
            switchTab(i)
        end)
    end

    -- ═══════════════════════════════════════
    --     مشوار الإشعارات (Toast Container)
    -- ═══════════════════════════════════════
    local toastContainer = CreateInstance("Frame", {
        Size            = UDim2.new(0, 260, 0, 0),
        Position        = UDim2.new(1, -270, 1, -20),
        AnchorPoint     = Vector2.new(0, 1),
        BackgroundTransparency = 1,
        AutomaticSize   = Enum.AutomaticSize.Y,
        ZIndex          = 20,
        Parent          = screenGui,
    })

    local toastLayout = Instance.new("UIListLayout")
    toastLayout.SortOrder = Enum.SortOrder.LayoutOrder
    toastLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
    toastLayout.Padding = UDim.new(0, 6)
    toastLayout.Parent = toastContainer
    _G.LuxToastContainer = toastContainer

    -- ═══════════════════════════════════════
    --     زر الإغلاق والتصغير
    -- ═══════════════════════════════════════
    closeBtn.MouseButton1Click:Connect(function()
        Tween(mainFrame, {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}, 0.3)
        task.delay(0.35, function()
            screenGui:Destroy()
        end)
    end)

    minBtn.MouseButton1Click:Connect(function()
        State.isMinimized = not State.isMinimized
        if State.isMinimized then
            Tween(mainFrame, {Size = UDim2.new(0, CONFIG.SIZES.WIDTH, 0, CONFIG.SIZES.HEADER_H)})
        else
            Tween(mainFrame, {Size = UDim2.new(0, CONFIG.SIZES.WIDTH, 0, CONFIG.SIZES.HEIGHT)})
        end
    end)

    -- ═══════════════════════════════════════
    --     السحب (Drag)
    -- ═══════════════════════════════════════
    local dragging, dragStart, startPos = false, nil, nil

    header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- ظهور الواجهة مع أنيميشن
    mainFrame.Size = UDim2.new(0, 0, 0, 0)
    mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
    Tween(mainFrame, {
        Size = UDim2.new(0, CONFIG.SIZES.WIDTH, 0, CONFIG.SIZES.HEIGHT),
        Position = UDim2.new(0.5, -CONFIG.SIZES.WIDTH / 2, 0.5, -CONFIG.SIZES.HEIGHT / 2)
    }, 0.4)

    return {
        screenGui    = screenGui,
        mainFrame    = mainFrame,
        tabPages     = tabPages,
        switchTab    = switchTab,
        setStatus    = SetStatus,
    }
end

